{
  "name": "opencv-ts-webgpu",
  "version": "0.2.6",
  "description": "OpenCV.ts 5.0 — TypeScript-first, WebGPU-native Computer Vision framework",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "mkdir -p demo/assets/ort && cp node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.jsep.wasm node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.wasm demo/assets/ort/",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "wasm:build": "cd wasm && wasm-pack build --target web --out-dir ../src/backends/wasm/pkg",
    "build:demo": "vite build --config vite.config.pages.ts && rm -rf demo-webapp/public && cp -r dist demo-webapp/public && cp demo/assets/josh-demo.mp4 demo-webapp/public/assets/ && cp -r demo/assets/models demo-webapp/public/assets/models && cp -r src/backends/wasm/pkg demo-webapp/public/assets/pkg"
  },
  "dependencies": {
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "onnxruntime-web": "^1.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@webgpu/types": "^0.1.52",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
